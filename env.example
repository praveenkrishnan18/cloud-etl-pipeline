# .env.example
# Copy this to .env and fill in your real values for LOCAL development.
# .env is in .gitignore — it will NEVER be committed.
# In GitHub Actions, these are stored as Repository Secrets.

AZURE_STORAGE_ACCOUNT_NAME=your_adls_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_account_key_here
ADLS_FILESYSTEM_NAME=raw
ADLS_OUTPUT_FOLDER=output
